{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @cadence/shared build && pnpm --filter @cadence/web build",
  "outputDirectory": "apps/web/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://cadence-api.onrender.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://cadence-api.onrender.com/health"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
